# ============================================================
# Artisan Connect — Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill with your real values.
# For Vercel deployment, add each variable in Settings → Environment Variables.
# ============================================================

# ============================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Connection pooling" URL for DATABASE_URL (port 6543)
# Use the "Direct connection" URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ============================================================
# JWT SECRET
# ============================================================
# Generate a strong random string (at least 32 characters)
# Run: openssl rand -base64 32
JWT_SECRET="change-this-to-a-strong-random-string-at-least-32-chars"

# ============================================================
# APP URL
# ============================================================
# For local dev: http://localhost:3000
# For Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# KKIAPAY (Primary payment provider)
# ============================================================
# Get your keys at https://kkiapay.me → Settings → API Keys
# - API_KEY = public key (starts with "pk_")
# - PRIVATE_KEY = private key (starts with "pk_priv_")
# - SECRET_KEY = webhook secret (for signature verification)
# Leave EMPTY to run in DEMO mode (payments auto-complete for testing)
KKIAPAY_API_KEY=""
KKIAPAY_PRIVATE_KEY=""
KKIAPAY_SECRET_KEY=""
KKIAPAY_SANDBOX="true"

# ============================================================
# CINETPAY (Legacy — optional, can be left empty)
# ============================================================
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""

# ============================================================
# SMTP (Email — for password reset)
# ============================================================
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# For Resend, SendGrid, etc.: use their SMTP credentials
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yourdomain.com"

# ============================================================
# Z.AI SDK (Chatbot — optional)
# ============================================================
# Get your key at https://z.ai
ZAI_API_KEY=""